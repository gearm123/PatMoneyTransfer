# Copy to .env — publishable key from Stripe Dashboard (pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=
# Required for production (Netlify, etc.): your Express API public URL, no trailing slash.
# If unset, the browser calls /api on the same host — static hosting has no API; use VITE_API_BASE
# and rebuild, or add a Netlify proxy (see netlify.toml comment).
# VITE_API_BASE=https://your-api.example.com
#
# Public site URL (HTTPS, no trailing slash) — bakes into sitemap, robots, canonical, and Open Graph.
# Set in Netlify to your live domain, e.g. https://yoursite.netlify.app
# VITE_PUBLIC_SITE_URL=https://example.com
#
# Google Analytics 4: measurement ID from Admin → Data streams (G-XXXXXXXX). Baked in at *build* time; restart `vite` after local edit.
# Netlify: Site configuration → Environment variables → add this key, then trigger “Clear cache and deploy site”.
# In DevTools → Network, filter "collect" (or look for google-analytics.com / googletagmanager.com). Ad blockers hide these.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXX
